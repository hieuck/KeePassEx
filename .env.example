# KeePassEx — Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── CLI ──────────────────────────────────────────────────────────────────────
# Default vault path for kpx CLI
KPX_VAULT=/path/to/your/vault.kdbx

# Master password (prefer interactive prompt for security)
# KPX_PASSWORD=your-master-password

# Key file path (optional)
# KPX_KEY_FILE=/path/to/keyfile.keyx

# ─── Desktop (Tauri) ──────────────────────────────────────────────────────────
# Code signing key for auto-updates
# TAURI_SIGNING_PRIVATE_KEY=...
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=...

# ─── macOS Code Signing ───────────────────────────────────────────────────────
# APPLE_CERTIFICATE=...
# APPLE_CERTIFICATE_PASSWORD=...
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)
# APPLE_ID=your@apple.id
# APPLE_PASSWORD=app-specific-password
# APPLE_TEAM_ID=YOURTEAMID

# ─── Android Signing ──────────────────────────────────────────────────────────
# KEEPASSEX_UPLOAD_STORE_FILE=/path/to/keystore.jks
# KEEPASSEX_UPLOAD_STORE_PASSWORD=...
# KEEPASSEX_UPLOAD_KEY_ALIAS=keepassex
# KEEPASSEX_UPLOAD_KEY_PASSWORD=...

# ─── Browser Extension ────────────────────────────────────────────────────────
# Chrome extension ID (for native messaging host)
# CHROME_EXTENSION_ID=your-extension-id-here

# Firefox extension ID
# FIREFOX_EXTENSION_ID=keepassex@keepassex.app

# ─── Development ──────────────────────────────────────────────────────────────
# Rust log level
RUST_LOG=keepassex=debug,warn

# Disable telemetry (already off by default)
KEEPASSEX_NO_TELEMETRY=1
