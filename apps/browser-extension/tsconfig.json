{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@keepassex/i18n": ["../../packages/i18n/src"],
      "@keepassex/types": ["../../shared/types/src"],
      "@keepassex/constants": ["../../shared/constants/src"],
      "@keepassex/utils": ["../../shared/utils/src"]
    }
  },
  "include": ["src", "popup.html"]
}
