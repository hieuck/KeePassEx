{
  "name": "@keepassex/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "KeePassEx Mobile — iOS & Android (React Native)",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build:android": "react-native build-android --mode=release",
    "build:ios": "react-native build-ios --mode=Release",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@keepassex/ui": "workspace:*",
    "@keepassex/i18n": "workspace:*",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "react-native-screens": "^4.4.0",
    "react-native-safe-area-context": "^4.14.0",
    "react-native-gesture-handler": "^2.21.2",
    "react-native-reanimated": "^3.16.6",
    "zustand": "^5.0.3",
    "@tanstack/react-query": "^5.62.16",
    "react-native-keychain": "^9.2.2",
    "react-native-biometrics": "^3.0.1",
    "react-native-camera": "^4.2.1",
    "react-native-document-picker": "^9.3.1",
    "react-native-fs": "^2.20.0",
    "react-native-share": "^10.2.1",
    "@react-native-clipboard/clipboard": "^1.14.3",
    "react-native-haptic-feedback": "^2.3.1",
    "react-native-quick-actions": "^0.3.7",
    "@react-native-async-storage/async-storage": "^2.1.0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.76.5",
    "@react-native/metro-config": "^0.76.5",
    "@react-native/typescript-config": "^0.76.5",
    "@types/react": "^18.3.12",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@testing-library/react-native": "^12.9.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1"
  }
}
