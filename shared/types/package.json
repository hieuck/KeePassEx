  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
