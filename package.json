{
  "name": "keepassex",
  "version": "1.0.0",
  "private": true,
  "description": "KeePassEx — Native cross-platform password manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/keepassex/keepassex"
  },
  "license": "GPL-3.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:rust": "cargo test --all --all-features",
    "test:ts": "vitest run --config vitest.config.ts",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "desktop": "pnpm --filter @keepassex/desktop dev",
    "mobile": "pnpm --filter @keepassex/mobile start",
    "cli": "cargo run -p keepassex-cli --",
    "extension:chrome": "pnpm --filter @keepassex/browser-extension build:chrome",
    "extension:firefox": "pnpm --filter @keepassex/browser-extension build:firefox",
    "audit:rust": "cargo audit",
    "fmt": "cargo fmt --all && pnpm prettier --write .",
    "check": "cargo clippy --all-targets -- -D warnings && pnpm typecheck && pnpm lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "vitest": "^2.1.8",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "shared/*"
  ]
}
